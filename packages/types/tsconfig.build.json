{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true
    },
    "include": ["src"],
    "exclude": ["src/**/*.spec.ts", "src/**/__tests__/**"]
}
