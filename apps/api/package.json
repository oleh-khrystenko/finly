        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.2"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts",
            "tsx"
        ],
        "rootDir": "src",
        "roots": [
            "<rootDir>",
            "<rootDir>/../scripts"
        ],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)sx?$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)sx?"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node",
        "setupFiles": [
            "./test-setup.ts"
        ],
        "moduleNameMapper": {
            "^@finly/types$": "<rootDir>/../../../packages/types/src/index.ts"
        }
    }
