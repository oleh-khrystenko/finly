# ===================
# Runtime
# ===================
NODE_ENV=development
PORT=4000
WEB_PORT=3000
API_PORT=4000
# Кількість довірених reverse-proxy перед API (Express trust proxy).
# 0 — без проксі (XFF ігнорується); 1 — за одним nginx/caddy; і т.д.
# Критично для per-IP rate-limit-ів: див. apps/api/src/config/env.ts.
TRUST_PROXY_HOPS=0

# ===================
# Backend (apps/api)
# ===================
# Cabinet origin (auth, billing, email).
WEB_URL=http://localhost:3000
# Public payment-page origin (host для QR на сторінку бізнесу).
PAY_PUBLIC_URL=http://pay.finly.local:3000

# MUST point at a Mongo replica-set. Standalone mongod is unsupported:
# Sprint 4 cascade-delete (видалення бізнесу разом із його інвойсами) виконується
# у `session.withTransaction`, а Mongo дозволяє транзакції лише на replica-set.
# Atlas dev cluster — replica-set за замовчуванням; для local dev — три варіанти
# у root README.md (секція "Mongo replica-set для local dev"). На standalone
# mongod cascade-delete падає з 500 `CASCADE_DELETE_REQUIRES_REPLICA_SET`.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<app>

REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=<generate-random-32-byte-hex>
JWT_REFRESH_SECRET=<generate-random-32-byte-hex>

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

RESEND_API_KEY=re_your_resend_api_key
# Production: verified domain sender (e.g. Finly <no-reply@finly.com.ua>)
RESEND_FROM_EMAIL=Finly <onboarding@resend.dev>

# monobank «Плата» (Sprint 22) — білінг під керуванням нашого billing-clock.
# X-Token із кабінету monobank (тестовий токен — з api.monobank.ua).
MONOBANK_TOKEN=test-monobank-token

PAYMENTS_SUBSCRIPTION_ENABLED=true
PAYMENTS_ONE_OFF_ENABLED=true
# Демо-режим білінгу (демо-банер на сторінці тарифу). На проді з живими грошима — false.
BILLING_DEMO_MODE=true

# Dunning (billing-clock): спроби списання у прострочці до зняття доступу та
# інтервал між повторами (год). Грейс ≈ MAX × INTERVAL (план: ~7 днів, ~3 повтори).
BILLING_DUNNING_MAX_ATTEMPTS=4
BILLING_DUNNING_RETRY_INTERVAL_HOURS=48

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Public Help Assistant (anon, no executions) ---
HELP_CHAT_MAX_TOKENS=800
HELP_CHAT_IP_LIMIT=20
HELP_CHAT_DAILY_BUDGET=1000

AUTH_PASSWORD_MIN_LENGTH=8
AUTH_LOCKOUT_THRESHOLDS=5:1,10:5,20:15
AUTH_LOGIN_ATTEMPTS_TTL_MIN=15
AUTH_MAGIC_LINK_TTL_MIN=15
AUTH_MAGIC_LINK_RATE_LIMIT=3
AUTH_MAGIC_LINK_RATE_WINDOW_MIN=15
AUTH_MAGIC_LINK_DEDUP_SEC=60
ACCOUNT_DELETION_GRACE_DAYS=30

# --- Orphan-Business cleanup pipeline (Sprint 12) ---
# 3-stage email + cron-cleanup для users без firstName/lastName, що мають
# orphan-Business. Cross-field invariant: FIRST < FINAL < DELETION (fail-fast у
# env.ts). FIRST ≥ 1 — grace-period між створенням Business і першим reminder.
# Збій інваріанту колапсує stages в один день і ламає compliance "user
# попереджений 2 рази перед видаленням".
ORPHAN_REMINDER_FIRST_DAYS=1
ORPHAN_REMINDER_FINAL_DAYS=6
ORPHAN_CLEANUP_DELETION_DAYS=7

# Sprint 21 — днів життя pending-логотипа бренду до cron-чистки з R2.
# PENDING — free-завантаження без оплати (короткий поріг).
# DEMOTED — знятий з active при згасанні тарифу (довший: даємо платнику час повернутись).
BRAND_PENDING_CLEANUP_DAYS=30
BRAND_DEMOTED_CLEANUP_DAYS=90

# --- Cloudflare R2 (media storage) ---
# R2_PUBLIC_URL hostname MUST equal NEXT_PUBLIC_STORAGE_HOSTNAME (below) —
# otherwise next/image rejects uploaded photos at runtime.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=finly-media
R2_PUBLIC_URL=https://media.finly.com.ua

# ===================
# Frontend (apps/web)
# ===================
API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
# Public payment-page origin (host для copy-link і QR на сторінку бізнесу).
# Має збігатись з PAY_PUBLIC_URL на api side.
NEXT_PUBLIC_PAY_PUBLIC_URL=http://pay.finly.local:3000

NEXT_PUBLIC_PAYMENTS_SUBSCRIPTION_ENABLED=true
NEXT_PUBLIC_PAYMENTS_ONE_OFF_ENABLED=true

# Демо-банер білінгу (тестова картка monobank, "кошти не списуються").
# Лише для sandbox-стадії. У проді МУСИТЬ бути false.
NEXT_PUBLIC_BILLING_DEMO_MODE=true

# Hostname of the R2 public CDN (MUST match the hostname of R2_PUBLIC_URL above).
NEXT_PUBLIC_STORAGE_HOSTNAME=media.finly.com.ua
